# .env.example
# ─────────────
# Copy this file to .env and fill in your credentials.
# Never commit .env to version control.

# Required: Your API key
# For OpenAI:           your key from platform.openai.com
# For Hugging Face:     your token from huggingface.co/settings/tokens
HF_TOKEN=your_api_key_here

# The API endpoint (default is OpenAI)
# For OpenAI:           https://api.openai.com/v1
# For HF Inference:     https://api-inference.huggingface.co/v1
API_BASE_URL=https://api.openai.com/v1

# The model to use
# OpenAI options:       gpt-4o-mini, gpt-4o, gpt-4-turbo
# HF options:           meta-llama/Llama-3.1-8B-Instruct, etc.
MODEL_NAME=gpt-4o-mini
